<%#
kind: provision
name: Kickstart bootc
model: ProvisioningTemplate
description: Kickstart template supporting both traditional RPM and bootc container installs.
             Set host parameter 'bootc_image_url' to enable image-mode installation.
-%>
<%
  rhel_compatible = @host.operatingsystem.family == 'Redhat'
  os_major = @host.operatingsystem.major.to_i
  bootc_url = host_param('bootc_image_url')
  use_bootc = bootc_url.present?
-%>
# Kickstart - <%= @host.operatingsystem %> on <%= @host.name %>
# Generated by Red Hat Satellite

lang en_US.UTF-8
keyboard us
timezone --utc <%= host_param('time-zone') || 'UTC' %>

network --bootproto=dhcp --device=link --activate --hostname=<%= @host.name %>

rootpw --iscrypted <%= root_pass %>

zerombr
clearpart --all --initlabel
<% if use_bootc -%>
autopart --type=plain
<% else -%>
autopart --type=lvm
<% end -%>

text
reboot

<% if use_bootc -%>
ostreecontainer --url=<%= bootc_url %> --transport=registry --no-signature-verification
<% else -%>
url --url=<%= medium_uri %>
<% end -%>

<% unless use_bootc -%>
%packages
@core
chrony
insights-client
rhc
%end
<% end -%>

%post --log=/root/ks-post.log
<%= snippet('redhat_register') %>

<% if host_param_true?('enable_insights') -%>
insights-client --register
<% end -%>

echo "Provisioning complete: $(date)" >> /root/ks-post.log
%end
